/**
 * Implements hook_page_attachments().
 * PURPOSE: Ensures the admin toolbar CSS is attached globally so the book icon appears.
 */
function book_management_page_attachments(array &$attachments) {
  $attachments['#attached']['library'][] = 'book_management/toolbar';
}

/**
 * Implements hook_node_view().
 * PURPOSE: The "Stability Engine". It finds [book_cards] text in node bodies 
 * and replaces it with the premium rendered HTML cards. This method is used instead 
 * of traditional shortcodes to prevent theme conflicts and server crashes.
 */
function book_management_node_view(array &$build, \Drupal\Core\Entity\EntityInterface $entity, \Drupal\Core\Entity\Display\EntityViewDisplayInterface $display, $view_mode) {
  if (!\Drupal::entityTypeManager()->hasDefinition('book_item')) {
    return;
  }
  if (isset($build['body'][0]['#text'])) {
    $text = $build['body'][0]['#text'];
    
    // Find all occurrences of the book_cards tag
    if (preg_match_all('/\[?book_cards(\s+id="([\d,]+)")?\]?/', $text, $matches, PREG_SET_ORDER)) {
      $final_text = $text;
      $has_rendered = FALSE;

      foreach ($matches as $match) {
        $full_tag = $match[0];
        $ids_string = !empty($match[2]) ? $match[2] : NULL;
        
        $rendered_html = book_management_render_books($ids_string);
        if ($rendered_html) {
          $final_text = str_replace($full_tag, $rendered_html, $final_text);
          $has_rendered = TRUE;
        }
      }

      if ($has_rendered) {
        $build['body'][0]['#text'] = Markup::create($final_text);
        $build['#attached']['library'][] = 'book_management/book_cards';
      }
    }
  }
}

/**
 * Implements hook_ENTITY_TYPE_view() for 'block_content'.
 * PURPOSE: Allows the shortcode to be placed inside Custom Blocks as well.
 */
function book_management_block_content_view(array &$build, \Drupal\Core\Entity\EntityInterface $entity, \Drupal\Core\Entity\Display\EntityViewDisplayInterface $display, $view_mode) {
  if (!\Drupal::entityTypeManager()->hasDefinition('book_item')) {
    return;
  }
  if (isset($build['body'][0]['#text'])) {
    $text = $build['body'][0]['#text'];
    
    // Find all occurrences of the book_cards tag
    if (preg_match_all('/\[?book_cards(\s+id="([\d,]+)")?\]?/', $text, $matches, PREG_SET_ORDER)) {
      $final_text = $text;
      $has_rendered = FALSE;

      foreach ($matches as $match) {
        $full_tag = $match[0];
        $ids_string = !empty($match[2]) ? $match[2] : NULL;
        
        $rendered_html = book_management_render_books($ids_string);
        if ($rendered_html) {
          $final_text = str_replace($full_tag, $rendered_html, $final_text);
          $has_rendered = TRUE;
        }
      }

      if ($has_rendered) {
        $build['body'][0]['#text'] = Markup::create($final_text);
        $build['#attached']['library'][] = 'book_management/book_cards';
      }
    }
  }
}

/**
 * Helper function to render book cards.
 * PURPOSE: Fetches data from the database and builds the Glassmorphism HTML structure.
 */
function book_management_render_books($ids_string = NULL) {
  try {
    $storage = \Drupal::entityTypeManager()->getStorage('book_item');
    $query = $storage->getQuery()->accessCheck(FALSE);
    
    if ($ids_string) {
      $ids = explode(',', $ids_string);
      $query->condition('id', $ids, 'IN');
    }
    
    $found_ids = $query->execute();
    if (empty($found_ids)) return "";

    $books = $storage->loadMultiple($found_ids);
    $output = '<div class="bm-book-grid">';
    
    $default_color = \Drupal::config('book_management.settings')->get('default_color') ?: '#6c5ce7';
    foreach ($books as $book) {
      $color = $book->get('color')->value ?: $default_color;
      $title = $book->label();
      $desc = $book->get('description')->value ?? '';
      $image_url = ($img = $book->get('image')->entity) ? \Drupal::service('file_url_generator')->generateAbsoluteString($img->getFileUri()) : "";
      $pdf_url = ($pdf = $book->get('pdf')->entity) ? \Drupal::service('file_url_generator')->generateAbsoluteString($pdf->getFileUri()) : "";
      
      $img_html = $image_url ? "<div class='bm-card-image-outer'><div class='bm-card-image'><img src='$image_url' alt='$title'></div></div>" : "";
      $btn_html = $pdf_url ? "<div class='bm-card-footer'><a href='$pdf_url' class='bm-btn-capsule' target='_blank'><span class='bm-btn-text'>Download</span></a></div>" : "";

      $output .= "
        <div class='bm-card-wrapper'>
          <div class='bm-glass-card' style='--card-color: $color'>
            <div class='bm-card-glow'></div>
            <div class='bm-card-content'>
              $img_html
              <div class='bm-card-info'>
                <h3 class='bm-card-title'>$title</h3>
                <div class='bm-card-description'>$desc</div>
                $btn_html
              </div>
            </div>
          </div>
        </div>";
    }
    $output .= '</div>';
    return $output;
  }
  catch (\Exception $e) {
    return "";
  }
}
